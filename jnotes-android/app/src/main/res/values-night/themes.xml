<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JNotes" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.JNotes.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1B1815</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.JNotes</item>
    </style>
</resources>
